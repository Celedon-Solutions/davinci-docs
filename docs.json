    "banner": {
        "content": "Davinci v4.2 is now available! [See what's new](/pages/release-notes/v4.2.0)",
        "dismissible": true
    },
    "footer": {
        "logo": {
            "dark": "/logo/dark.svg",
            "light": "/logo/light.svg"
        },
        "copyright": "© 2026 Celedon Solutions, Inc",
        "socials": {
            "bluesky": "https://bsky.app/profile/celedon.solutions",
            "x": "https://x.com/Celedon_inc",
            "linkedin": "https://www.linkedin.com/company/celedon-solutions-inc",
            "github": "https://github.com/Celedon-Solutions"
        },
        "links": [
            {
                "header": "Company",
                "items": [
                    {
                        "label": "About",
                        "href": "https://celedon.solutions/about"
                    },
                    {
                        "label": "Careers",
                        "href": "https://celedon.solutions/careers"
                    },
                    {
                        "label": "Contact",
                        "href": "https://celedon.solutions/contact"
                    }
                ]
            },
            {
                "header": "Legal",
                "items": [
                    {
                        "label": "Terms of Service",
                        "href": "https://celedon.solutions/terms-of-service/"
                    },
                    {
                        "label": "Credit Policy",
                        "href": "https://celedon.solutions/credit-policy/"
                    },
                    {
                        "label": "Privacy Policy",
                        "href": "https://celedon.solutions/privacy-policy/"
                    },
                    {
                        "label": "Third Party Policy",
                        "href": "https://celedon.solutions/third-party-policies/"
                    }
                ]
            }
            
        ]
    },
    "navbar": {
        "links": [
            {
                "label": "Celedon Solutions",
                "href": "https://www.celedon.solutions/"
            }
        ],
        "primary": {
            "type": "button",
            "href": "https://davinci-app.com",
            "label": "Use Davinci"
        }
    },
    "api": {
        "openapi": {
            "source": "openapi/davinci-public.v2.yaml",
            "directory": "api-reference"
        },
        "playground": {
            "display": "interactive",
            "proxy": true
        },
        "params": {
            "expanded": "all"
        },
        "url": "full",
        "examples": {
            "languages": [
                "bash",
                "python",
                "typescript",
                "javascript"
            ],
            "defaults": "required",
            "prefill": true,
            "autogenerate": true
        }
    },
