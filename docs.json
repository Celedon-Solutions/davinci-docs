{
    "$schema": "https://mintlify.com/docs.json",
    "name": "Davinci",
    "theme": "mint",
    "appearance": {
        "default": "dark",
        "strict": false
    },
    "logo": {
        "dark": "/logo/logo_small_dark.svg",
        "light": "/logo/logo_small_bright.svg"
    },
    "favicon": "/logo/fav_icon_dark.svg",
